                <!-- ===== 1. ВЫБОР ТИПА ФИГУРЫ ===== -->
                <TextBlock Text="1. Выберите тип фигуры:" 
                           FontWeight="Bold"
                           Foreground="#E0E0E0"
                           Margin="0,0,0,5"/>

                <ComboBox x:Name="cmbShapeType" 
                          ItemsSource="{Binding ShapeTypeNames}"
                          SelectedItem="{Binding SelectedShapeType}"
                          Height="30"
                          Margin="0,0,0,15"
                          Background="#3E3E42"
                          Foreground="black"
                          BorderBrush="#555"/>

                <!-- Кнопка создания -->
                <Button Content="Создать фигуру" 
                        Command="{Binding CreateShapeCommand}"
                        Background="#6A4E9B"
                        Foreground="White"
                        Height="35"
                        FontWeight="Bold"
                        Margin="0,0,0,15"
                        Cursor="Hand"/>

                <Rectangle Height="1" Fill="#3E3E42" Margin="0,0,0,15"/>

                <!-- ===== 2. ВВОД КООРДИНАТ ===== -->
                <TextBlock Text="2. Введите координаты точки:" 
                           FontWeight="Bold"
                           Foreground="#E0E0E0"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="X:" Foreground="#9CDCFE" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding InputX, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="30"
                                 Background="#3E3E42"
                                 Foreground="White"
                                 BorderBrush="#555"
                                 CaretBrush="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Y:" Foreground="#9CDCFE" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding InputY, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="30"
                                 Background="#3E3E42"
                                 Foreground="White"
                                 BorderBrush="#555"
                                 CaretBrush="White"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопка добавления точки -->
                <Button Content="Добавить точку" 
                        Command="{Binding AddPointCommand}"
                        CommandParameter="{Binding ElementName=MyCanvas}"
                        Background="#0E639C"
                        Foreground="White"
                        Height="35"
                        FontWeight="Bold"
                        Margin="0,0,0,15"
                        Cursor="Hand"/>

                <Rectangle Height="1" Fill="#3E3E42" Margin="0,0,0,15"/>

                <!-- ===== 3. УПРАВЛЕНИЕ ФИГУРАМИ ===== -->
                <TextBlock Text="3. Список фигур:" 
                           FontWeight="Bold"
                           Foreground="#E0E0E0"
                           Margin="0,0,0,5"/>

                <ListBox Height="150" 
                         ItemsSource="{Binding CollectionShapes.ListShapes}"
                         SelectedItem="{Binding SelectedShape}"
                         Background="#2D2D2D"
                         BorderBrush="#555"
                         Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameShape}" Padding="5" Foreground="#E0E0E0"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Нарисовать все" 
                            Command="{Binding DrawAllShapesCommand}"
                            CommandParameter="{Binding ElementName=MyCanvas}"
                            Background="#007ACC"
                            Foreground="White"
                            Height="35"
                            Margin="0,0,5,0"
                            FontWeight="Bold"
                            Cursor="Hand"/>

                    <Button Grid.Column="1" Content="Удалить" 
                            Command="{Binding DeleteShapeCommand}"
                            Background="#D32F2F"
                            Foreground="White"
                            Height="35"
                            Margin="5,0,0,0"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </Grid>

