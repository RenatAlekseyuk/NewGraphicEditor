                <!-- Информация -->
                <Border Background="#2D2D2D" CornerRadius="3" Padding="8" Margin="0,5,0,0" BorderBrush="#555" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Информация:" FontWeight="Bold" Foreground="#9CDCFE" Margin="0,0,0,5"/>
